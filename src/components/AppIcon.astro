---
// ⚡ Bolt Optimization: Manually inlining the logo SVG using Vite's ?raw import.
// This prevents a blocking network request for a critical above-the-fold asset.
import logoRaw from "../../public/logo.svg?raw";

interface Props {
  alt?: string;
  className?: string;
  imageClassName?: string;
}

// Ensure alt="" is respected for decorative images (don't fall back to "Mietfolio Logo" if explicitly empty)
const { alt, className = "", imageClassName = "" } = Astro.props;
---
<span
  class:list={["inline-flex shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white", className]}
  role="img"
  aria-label={alt !== undefined ? alt : "Mietfolio Logo"}
>
  <span
    class:list={["flex h-full w-full items-center justify-center [&_svg]:h-full [&_svg]:w-full [&_svg]:object-contain", imageClassName]}
    draggable="false"
  >
    <Fragment set:html={logoRaw} />
  </span>
</span>
