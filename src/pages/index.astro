                    />
                  ) : null}
                  <div class="relative flex h-12 w-12 items-center justify-center rounded-full border border-[#006b5b] bg-white font-label text-sm font-black text-[#006b5b]">
                    {step.number}
                  </div>
                </div>
                <h3 class="mt-6 font-headline text-lg font-extrabold text-[#0b1422]">{step.title}</h3>
                <p class="mt-3 flex-1 text-sm leading-6 text-[#5c6b74]">{step.text}</p>
              </article>
            ))}
          </div>

          <div class="hidden items-center justify-end self-center lg:flex">
