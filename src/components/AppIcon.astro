---
// ⚡ Bolt: Import raw SVG to inline it and avoid extra network request (LCP/FCP optimization)
import logoSvg from '../../public/logo.svg?raw';

interface Props {
  alt?: string;
  className?: string;
  imageClassName?: string;
}

const { alt = "", className = "", imageClassName = "" } = Astro.props;
---
<span class:list={["inline-flex shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white", className]}>
  <span
    role={alt ? "img" : "presentation"}
    aria-label={alt || undefined}
    aria-hidden={!alt ? "true" : undefined}
    class:list={[
      "flex h-full w-full items-center justify-center",
      "[&_svg]:h-full [&_svg]:w-full [&_svg]:object-contain",
      imageClassName
    ]}
    set:html={logoSvg}
  />
</span>
