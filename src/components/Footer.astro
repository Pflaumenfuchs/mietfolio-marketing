---
import BrandLogo from "./BrandLogo.astro";
import { Mail } from "@lucide/astro";

interface Props {
  locale?: "de" | "en";
}

const { locale = "de" } = Astro.props;
const currentYear = new Date().getFullYear();

const copy = locale === "en"
  ? {
      homeHref: "/en",
      homeLabel: "Mietfolio homepage",
      text: "Mietfolio bundles key landlord workflows into one clear property-based system.",
      rights: "All rights reserved.",
      productLabel: "Product",
      productNavLabel: "Product links",
      legalLabel: "Legal",
      legalNavLabel: "Legal links",
      contactLabel: "Contact",
      contactNote: "Legal notice and privacy information are currently provided on the German legal pages.",
      navItems: [
        ["Features", "/en#features"],
        ["Workflow", "/en#workflow"],
        ["Security", "/en#security"],
        ["Pricing", "/en#pricing"],
        ["FAQ", "/en#faq"],
      ],
      contentLinks: [
        ["Service Charges", "/funktionen/nebenkostenabrechnung"],
        ["Documents", "/funktionen/dokumentenverwaltung-vermieter"],
        ["Smoke Alarms", "/funktionen/rauchmelder-verwaltung"],
        ["Tenant Communication", "/funktionen/mieterkommunikation"],
        ["Tenant Portal", "/funktionen/mieterportal"],
        ["Reminders", "/funktionen/hinweise-fristen"],
        ["Properties", "/funktionen/immobilienverwaltung"],
      ],
      legalLinks: [
        ["Legal notice", "/impressum"],
        ["Privacy", "/datenschutz"],
        ["Terms", "/agb"],
      ],
    }
  : {
      homeHref: "/",
      homeLabel: "Mietfolio Startseite",
      text: "Mietfolio bündelt die wichtigsten Vermieteraufgaben in einem klaren, objektbezogenen System.",
      rights: "Alle Rechte vorbehalten.",
      productLabel: "Produkt",
      productNavLabel: "Produktlinks",
      legalLabel: "Rechtliches",
      legalNavLabel: "Rechtliches",
      contactLabel: "Kontakt",
      contactNote: "Impressum- und Datenschutzhinweise sind auf den Rechtsseiten hinterlegt.",
      navItems: [
        ["Funktionen", "/#funktionen"],
        ["Ablauf", "/#ablauf"],
        ["Sicherheit", "/#sicherheit"],
        ["Preis", "/#preis"],
        ["FAQ", "/#faq"],
      ],
      contentLinks: [
        ["Nebenkosten", "/funktionen/nebenkostenabrechnung"],
        ["Dokumente", "/funktionen/dokumentenverwaltung-vermieter"],
        ["Rauchmelder", "/funktionen/rauchmelder-verwaltung"],
        ["Mieterkommunikation", "/funktionen/mieterkommunikation"],
        ["Mieterportal", "/funktionen/mieterportal"],
        ["Hinweise", "/funktionen/hinweise-fristen"],
        ["Immobilien", "/funktionen/immobilienverwaltung"],
        ["Ratgeber", "/ratgeber/nebenkostenabrechnung-private-vermieter"],
      ],
      legalLinks: [
        ["Impressum", "/impressum"],
        ["Datenschutz", "/datenschutz"],
        ["AGB", "/agb"],
      ],
    };
---
<footer class="border-t border-[#dfe9e6] bg-white">
  <div class="mx-auto grid max-w-[1440px] gap-9 px-5 py-10 text-sm text-[#5c6b74] sm:px-8 md:grid-cols-[1.25fr_0.75fr_0.75fr_0.75fr] lg:px-12">
    <div>
      <a href={copy.homeHref} aria-label={copy.homeLabel}>
        <BrandLogo
          iconClassName="h-9 w-9 border border-[rgba(10,102,87,0.15)] shadow-[0_8px_24px_rgba(3,36,32,0.08)] sm:h-10 sm:w-10"
          textClassName="font-headline text-xl font-black text-brand-wordmark sm:text-2xl"
        />
      </a>
      <p class="mt-5 max-w-sm leading-7">
        {copy.text}
      </p>
      <p class="mt-6 text-xs font-semibold text-[#5c6b74]">© {currentYear} Mietfolio. {copy.rights}</p>
    </div>

    <nav class="grid content-start gap-3 font-label font-semibold" aria-label={copy.productNavLabel}>
      <h2 class="font-headline text-sm font-black uppercase tracking-[0.16em] text-[#0b1422]">{copy.productLabel}</h2>
      {copy.navItems.map(([label, href]) => (
        <a class="rounded-md transition hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href={href}>
          {label}
        </a>
      ))}
      {copy.contentLinks.map(([label, href]) => (
        <a class="rounded-md transition hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href={href}>
          {label}
        </a>
      ))}
      <a class="rounded-md transition hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href="/auth">
        Login
      </a>
    </nav>

    <nav class="grid content-start gap-3 font-label font-semibold" aria-label={copy.legalNavLabel}>
      <h2 class="font-headline text-sm font-black uppercase tracking-[0.16em] text-[#0b1422]">{copy.legalLabel}</h2>
      {copy.legalLinks.map(([label, href]) => (
        <a class="rounded-md transition hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href={href}>
          {label}
        </a>
      ))}
    </nav>

    <div class="grid content-start gap-3">
      <h2 class="font-headline text-sm font-black uppercase tracking-[0.16em] text-[#0b1422]">{copy.contactLabel}</h2>
      <a class="inline-flex items-center gap-2 rounded-md font-label font-semibold transition hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href="/kontakt">
        <Mail class="h-4 w-4" stroke-width={2} />
        kontakt@mietfolio.de
      </a>
      <p class="text-xs leading-6 text-[#5c6b74]">{copy.contactNote}</p>
    </div>
  </div>
</footer>
