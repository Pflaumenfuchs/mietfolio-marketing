                  <a class="mt-auto inline-flex items-center rounded-md pt-5 font-label text-sm font-bold text-[#006b5b] transition group-hover:text-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href={href} aria-label={`${title} Details ansehen`}>
                    Details ansehen
                    <ChevronRight class="ml-1 h-4 w-4" />
                  </a>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="app-ueberblick" class="scroll-mt-20 bg-[#003f3f] text-white">
