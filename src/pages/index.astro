            </div>
            <div class="mt-5 space-y-4">
              {messageItems.map((item, index) => (
                <div class="flex gap-3">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#f3c47c] font-label text-xs font-black text-[#3d2604]">
