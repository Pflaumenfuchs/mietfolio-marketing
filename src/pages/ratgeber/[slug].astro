---
import Layout from "../../layouts/Layout.astro";
import BrandLogo from "../../components/BrandLogo.astro";
import { ArrowLeft, ArrowRight, Check, Mail } from "@lucide/astro";
import { guidePages } from "../../data/seoContent";

export async function getStaticPaths() {
  return Object.keys(guidePages).map((slug) => ({
    params: { slug },
    props: { page: guidePages[slug] },
  }));
}

const { page } = Astro.props;
const currentYear = new Date().getFullYear();
const copyrightNotice = `© ${currentYear} Mietfolio. Alle Rechte vorbehalten.`;

// Build FAQ Schema JSON-LD
const faqJsonLd = page.faqs?.length
  ? {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "FAQPage",
          "@id": `https://mietfolio.de${page.path}#faq`,
          mainEntity: page.faqs.map((item) => ({
            "@type": "Question",
            name: item.question,
            acceptedAnswer: {
              "@type": "Answer",
              text: item.answer,
            },
          })),
        },
      ],
    }
  : null;
---
<Layout
  title={page.title}
  description={page.description}
  canonicalPath={page.path}
>
  {faqJsonLd && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(faqJsonLd)}
    />
  )}

  <div class="min-h-screen bg-white font-body text-[#0b1422] antialiased selection:bg-[#bff3e5] selection:text-[#06231f]">
    <header class="border-b border-[#dfe9e6] bg-white">
      <div class="mx-auto flex h-16 max-w-[1080px] items-center justify-between px-5 sm:px-8">
        <a
          class="inline-flex items-center gap-3 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4"
          href="/"
          aria-label="Mietfolio Startseite"
        >
          <BrandLogo
            iconClassName="h-10 w-10 border border-[rgba(10,102,87,0.15)] shadow-[0_8px_24px_rgba(3,36,32,0.08)]"
            textClassName="font-headline text-2xl font-black text-brand-wordmark"
          />
        </a>
        <a
          class="inline-flex items-center rounded-md font-label text-sm font-bold text-[#006b5b] transition hover:text-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4"
          href="/"
        >
          <ArrowLeft class="mr-2 h-4 w-4" />
          Startseite
        </a>
      </div>
    </header>

    <main>
      <article class="mx-auto grid max-w-[1080px] gap-10 px-5 py-12 sm:px-8 sm:py-16 lg:grid-cols-[1fr_280px]">
        <div>
          <p class="font-label text-sm font-bold uppercase tracking-[0.18em] text-[#006b5b]">Mietfolio Wissen</p>
          <h1 class="mt-4 max-w-3xl break-words font-headline text-4xl font-black leading-tight text-[#0b1422] hyphens-auto sm:text-5xl">
            {page.h1}
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-[#2d3d49]">{page.intro}</p>
          
          <!-- NextStepCard on Mobile -->
          <aside class="mt-8 rounded-lg border border-[#dfe9e6] bg-[#fbfdfc] p-5 lg:hidden">
            <h2 class="font-headline text-lg font-black text-[#0b1422]">Nächster Schritt</h2>
            <p class="mt-3 text-sm leading-6 text-[#5c6b74]">
              Mietfolio ist aktuell über die Warteliste erreachbar. Bestehende Nutzer können sich weiter anmelden.
            </p>
            <a
              class="mt-5 inline-flex h-11 w-full items-center justify-center rounded-md bg-[#006b5b] px-4 font-label text-sm font-bold text-white shadow-[0_12px_28px_rgba(0,107,91,0.22)] transition hover:bg-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4"
              href="/warteliste"
            >
              {page.cta}
              <ArrowRight class="ml-2 h-4 w-4" />
            </a>

            <div class="mt-8 border-t border-[#dfe9e6] pt-5">
              <h3 class="font-headline text-sm font-black uppercase tracking-[0.16em] text-[#0b1422]">Verwandte Seiten</h3>
              <nav class="mt-4 grid gap-3 font-label text-sm font-semibold">
                {page.related.map(([label, href]) => (
                  <a class="text-[#006b5b] transition hover:text-[#005346]" href={href}>
                    {label}
                  </a>
                ))}
              </nav>
            </div>
          </aside>

          <div class="mt-10 space-y-10">
            {page.sections.map((section) => (
              <section class="border-t border-[#dfe9e6] pt-8">
                <h2 class="font-headline text-2xl font-black leading-tight text-[#0b1422]">{section.title}</h2>
                <p class="mt-4 text-base leading-8 text-[#2d3d49]">{section.body}</p>
                {section.points ? (
                  <ul class="mt-5 grid gap-3">
                    {section.points.map((point) => (
                      <li class="flex gap-3 text-sm font-semibold leading-6 text-[#2d3d49]">
                        <Check class="mt-0.5 h-5 w-5 shrink-0 text-[#006b5b]" stroke-width={2.2} />
                        <span>{point}</span>
                      </li>
                    ))}
                  </ul>
                ) : null}
              </section>
            ))}

            {page.faqs && page.faqs.length > 0 && (
              <section id="faq" class="border-t border-[#dfe9e6] pt-8">
                <h2 class="font-headline text-2xl font-black leading-tight text-[#0b1422]">Häufige Fragen</h2>
                <div class="mt-5 grid gap-3">
                  {page.faqs.map((item) => (
                    <details class="rounded-lg border border-[#dfe9e6] bg-[#fbfdfc] p-5 open:bg-white">
                      <summary class="cursor-pointer list-none font-headline text-base font-extrabold text-[#0b1422] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35">
                        {item.question}
                      </summary>
                      <p class="mt-4 text-sm leading-7 text-[#2d3d49]">{item.answer}</p>
                    </details>
                  ))}
                </div>
              </section>
            )}
          </div>
        </div>

        <!-- NextStepCard on Desktop -->
        <aside class="sticky top-6 hidden h-fit rounded-lg border border-[#dfe9e6] bg-[#fbfdfc] p-5 lg:block">
          <h2 class="font-headline text-lg font-black text-[#0b1422]">Nächster Schritt</h2>
          <p class="mt-3 text-sm leading-6 text-[#5c6b74]">
            Mietfolio ist aktuell über die Warteliste erreichbar. Bestehende Nutzer können sich weiter anmelden.
          </p>
          <a
            class="mt-5 inline-flex h-11 w-full items-center justify-center rounded-md bg-[#006b5b] px-4 font-label text-sm font-bold text-white shadow-[0_12px_28px_rgba(0,107,91,0.22)] transition hover:bg-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4"
            href="/warteliste"
          >
            {page.cta}
            <ArrowRight class="ml-2 h-4 w-4" />
          </a>

          <div class="mt-8 border-t border-[#dfe9e6] pt-5">
            <h3 class="font-headline text-sm font-black uppercase tracking-[0.16em] text-[#0b1422]">Verwandte Seiten</h3>
            <nav class="mt-4 grid gap-3 font-label text-sm font-semibold">
              {page.related.map(([label, href]) => (
                <a class="text-[#006b5b] transition hover:text-[#005346]" href={href}>
                  {label}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      </article>
    </main>

    <footer class="border-t border-[#dfe9e6] bg-[#fbfdfc]">
      <div class="mx-auto flex max-w-[1080px] flex-col gap-4 px-5 py-8 text-sm text-[#5c6b74] sm:px-8 md:flex-row md:items-center md:justify-between">
        <span>{copyrightNotice}</span>
        <nav class="flex flex-wrap gap-5 font-label font-semibold">
          <a class="transition hover:text-[#006b5b]" href="/datenschutz">
            Datenschutz
          </a>
          <a class="transition hover:text-[#006b5b]" href="/impressum">
            Impressum
          </a>
          <a class="inline-flex items-center gap-2 transition hover:text-[#006b5b]" href="/kontakt">
            <Mail class="h-4 w-4" stroke-width={2} />
            Kontakt
          </a>
        </nav>
      </div>
    </footer>
  </div>
</Layout>
