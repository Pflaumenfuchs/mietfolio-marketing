              <span>Vorgang</span>
              <span>Objekt</span>
              <span>Status</span>
            </div>
            <div>
              {operationRows.map(([date, title, property, status, color]) => (
                <div class="grid gap-2 border-b border-white/10 px-4 py-4 text-sm last:border-b-0 md:grid-cols-[105px_1.2fr_1fr_120px] md:items-center md:gap-4 md:px-5">
