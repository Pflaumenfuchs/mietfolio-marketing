              <div class="absolute -bottom-6 -left-6 h-20 w-20 rounded-full bg-[#e6f5f0]/85" />
              <div class="absolute -top-6 -right-6 h-16 w-16 rounded-full bg-[#e6f5f0]/50" />
              
              <div class="relative h-16 w-16 text-[#006b5b]">
                <Building2 class="absolute bottom-0 left-0 h-14 w-14" strokeWidth={1.25} />
                <div class="absolute -bottom-1 -right-1 flex h-8 w-8 items-center justify-center rounded-lg border border-[#d9ebe6] bg-white text-[#006b5b] shadow-sm">
                  <Home class="h-5 w-5 text-[#4ea896]" strokeWidth={1.6} />
                </div>
              </div>
            </div>
          </div>
        </div>
