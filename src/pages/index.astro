                  <ul class="mt-4 grid gap-2">
                    {points.map((point) => (
                      <li class="flex gap-2 text-xs font-semibold leading-5 text-[#2d3d49]">
                        <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#006b5b]" strokeWidth={2.2} />
