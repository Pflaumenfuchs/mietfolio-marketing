---
import logoSvg from "../../public/logo.svg?raw";

interface Props {
  alt?: string;
  className?: string;
  imageClassName?: string;
}

const { alt = "", className = "", imageClassName = "" } = Astro.props;
---
<span class:list={["inline-flex shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white", className]}>
  {/* Inline SVG manually using set:html to avoid network requests and improve LCP.
      Applying ARIA attributes and classes on the wrapper to keep the SVG safe from regex. */}
  <span
    class:list={["[&>svg]:h-full [&>svg]:w-full [&>svg]:object-contain", imageClassName]}
    aria-label={alt || undefined}
    role={alt ? "img" : undefined}
    aria-hidden={!alt ? "true" : undefined}
    set:html={logoSvg}
  />
</span>
