              <ul class="mt-6 space-y-3">
                {pricingPoints.map((item) => (
                  <li class="flex gap-3 text-sm leading-6 text-[#2d3d49]">
                    <Check class="mt-0.5 h-5 w-5 shrink-0 text-[#006b5b]" strokeWidth={2.2} />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>

            <div class="grid gap-4">
              <article class="rounded-lg border border-[#dfe9e6] bg-white p-5">
                <Server class="h-7 w-7 text-[#006b5b]" strokeWidth={1.8} />
