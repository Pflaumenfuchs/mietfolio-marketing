---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AppIcon from "../components/AppIcon.astro";
import MaterialSymbol from "../components/MaterialSymbol.astro";

import {
  ArrowRight,
  Bell,
  Building2,
  Check,
  CheckCircle2,
  ChevronRight,
  Euro,
  FileText,
  FolderOpen,
  LockKeyhole,
  Mail,
  ReceiptText,
  Server,
  ShieldCheck,
  UsersRound,
  Radio,
} from "@lucide/astro";

const proofItems = [
  {
    icon: ShieldCheck,
    title: "Privacy-aware",
    text: "Data stays separated by property and remains traceable.",
  },
  {
    icon: LockKeyhole,
    title: "Secure access",
    text: "Supabase Auth and Row Level Security provide the technical basis.",
  },
  {
    icon: FileText,
    title: "Exports & proof",
    text: "Draft and final PDFs, logs, ZIP files and data exports.",
  },
  {
    icon: CheckCircle2,
    title: "Built for landlords",
    text: "From the first property to reviewed imports and tenant releases.",
  },
] as const;

const workflowSteps = [
  {
    number: "01",
    title: "Create a property",
    text: "Capture the property, owner details and core records once.",
  },
  {
    number: "02",
    title: "Bundle documents",
    text: "Keep documents, tenant access, smoke alarms, messages and notes structured.",
  },
  {
    number: "03",
    title: "Review and export",
    text: "Confirm imports, clarify deadlines, review tenant input and create exports.",
  },
] as const;

const modules = [
  {
    icon: ReceiptText,
    title: "Service charges",
    text: "Billing years, cost items, meter readings, allocation keys and CO2 shares with review status.",
    points: ["AI import with review", "Draft and final PDFs", "Year comparison"],
  },
  {
    icon: FolderOpen,
    title: "Documents",
    text: "Contracts, invoices and receipts with categories, preview, duplicate hints and bulk actions.",
    points: ["AI sorting support", "Tenant releases", "ZIP export"],
  },
  {
    icon: UsersRound,
    title: "Tenants & portal",
    text: "Master data, lease periods, payment details, invitations and reviewed profile changes.",
    points: ["Invite access", "Review uploads", "Control self-service"],
  },
  {
    icon: Mail,
    title: "Messages",
    text: "Calls, emails, internal notes and real tenant-portal conversations remain traceable.",
    points: ["Tenant context", "Portal replies", "Search and filters"],
  },
  {
    icon: Bell,
    title: "Reminders",
    text: "Manual reminders plus automatically derived lease-end and smoke-alarm tasks.",
    points: ["Priorities", "Due dates", "Source links"],
  },
  {
    icon: Radio,
    title: "Smoke alarms",
    text: "Inventory, photos, maintenance logs, tenant maintenance reviews and PDF protocols.",
    points: ["Photo assignment", "AI document import", "Inspection logs"],
  },
  {
    icon: Building2,
    title: "Properties",
    text: "Multiple properties with active context, owner data, living area, state and internal notes.",
    points: ["Property switcher", "Owner details", "Data export"],
  },
] as const;

const securityItems = [
  "Property scoping keeps data tied to the right object",
  "Row Level Security protects user boundaries at database level",
  "Transparent exports for your own archive",
  "Clear workflows instead of hidden black-box processes",
] as const;

const pricingPoints = [
  "Reserve early access without creating an account immediately",
  "Get notified when registration opens again",
  "Existing users can keep logging in normally",
  "Paid plans will be clearly shown before checkout",
] as const;

const faqItems = [
  {
    question: "What does Mietfolio cost?",
    answer:
      "The start is free. If paid plans are activated, price, scope and term are shown clearly before booking.",
  },
  {
    question: "Who is Mietfolio for?",
    answer:
      "Private landlords and small property managers who want service charges, documents, tenant communication, smoke alarms and reminders in one place.",
  },
  {
    question: "Can I manage multiple properties?",
    answer:
      "Yes. Mietfolio works with an active property context, so records and tasks stay separated by property.",
  },
  {
    question: "What can the tenant portal do?",
    answer:
      "Landlords can invite tenant access, share selected documents, review uploads, answer portal messages and enable smoke-alarm maintenance self-service.",
  },
  {
    question: "Where is the data stored?",
    answer:
      "Mietfolio uses Supabase for authentication, database and storage, including edge functions and storage. The German privacy policy contains the full processor and region details.",
  },
  {
    question: "Does Mietfolio replace legal or tax advice?",
    answer:
      "No. Mietfolio helps with structure, documentation and preparation, but it does not replace individual legal or tax advice.",
  },
] as const;

const previewSidebarLinks = [
  ["dashboard", "Overview", true],
  ["receipt_long", "Charges", false],
  ["domain", "Properties", false],
  ["groups", "Tenants", false],
  ["forum", "Messages", false],
  ["notifications", "Tasks", false],
  ["description", "Documents", false],
  ["build", "Alarms", false],
] as const;

const previewCostItems = [
  ["Property tax", "1,240.50 EUR", "Allocable", "account_balance"],
  ["Insurance", "892.30 EUR", "Allocable", "shield"],
  ["Water", "684.10 EUR", "Meter readings kept", "water_drop"],
  ["Heating service", "420.00 EUR", "Reviewed", "heat_pump"],
] as const;

const mobilePreviewTabs = [
  ["dashboard", "Home", true],
  ["groups", "Tenants", false],
  ["description", "Docs", false],
  ["build", "Service", false],
  ["notifications", "Tasks", false],
] as const;

const billingYear = new Date().getFullYear();

function getDemoBaseDate() {
  const date = new Date();
  date.setHours(12, 0, 0, 0);
  return date;
}

function getDateOffset(offsetDays: number) {
  const date = getDemoBaseDate();
  date.setDate(date.getDate() + offsetDays);
  return date;
}

const demoDateFormatter = new Intl.DateTimeFormat("en-GB", {
  day: "2-digit",
  month: "short",
  year: "numeric",
});

const demoShortDateFormatter = new Intl.DateTimeFormat("en-GB", {
  day: "2-digit",
  month: "2-digit",
});

function formatDemoDate(offsetDays: number) {
  return demoDateFormatter.format(getDateOffset(offsetDays));
}

function formatDemoShortDate(offsetDays: number) {
  return demoShortDateFormatter.format(getDateOffset(offsetDays));
}

function getDueLabel(offsetDays: number) {
  if (offsetDays === 0) return "Today";
  if (offsetDays === 1) return "Due tomorrow";
  return offsetDays > 1 ? `Due in ${offsetDays} days` : `${Math.abs(offsetDays)} days overdue`;
}

const operationRows = [
  [formatDemoDate(3), "Smoke alarm check", "Sample Street 12", getDueLabel(3), "bg-[#ff5a42]"],
  [formatDemoDate(11), "Heating service", "Sample Street 12", getDueLabel(11), "bg-[#f0a83a]"],
  [formatDemoDate(17), `Service charge statement ${billingYear}`, "Sample Street 12", getDueLabel(17), "bg-[#ffcf5a]"],
  [formatDemoDate(22), "Lease end review", "Apartment 1 left", `In ${22} days`, "bg-[#4ea8ff]"],
] as const;

const previewReminders = [
  ["Check smoke alarms", formatDemoDate(2)],
  ["Finalize charges", formatDemoDate(17)],
  ["Review lease end", formatDemoDate(22)],
] as const;

const mobilePreviewTasks = [
  [`Charges ${billingYear}`, formatDemoShortDate(17), "receipt_long"],
  ["Alarm check", formatDemoShortDate(2), "build"],
] as const;

const messageItems = ["Question about statement", `Service charges ${billingYear}`, "Schedule appointment"] as const;
---
<Layout
  lang="en"
  ogLocale="en_US"
  ogLocaleAlternate="de_DE"
  title="Mietfolio | Rental management, service charges and documents in one system"
  description="Mietfolio bundles service charges, documents, tenants, messages, smoke alarms and deadlines for private landlords in one clear SaaS app."
  canonicalPath="/en"
  socialImagePath="/og-image-en.png"
  socialImageAlt="Mietfolio social preview with logo and product message"
  alternateLinks={[
    { hreflang: "de", href: "https://mietfolio.de/" },
    { hreflang: "en", href: "https://mietfolio.de/en" },
    { hreflang: "x-default", href: "https://mietfolio.de/" },
  ]}
>
  <Header locale="en" />

  <div class="min-h-screen bg-white font-body text-[#0b1422] antialiased selection:bg-[#bff3e5] selection:text-[#06231f]">
    <main id="top">
      <section class="relative flex overflow-hidden border-b border-[#dfe9e6] bg-[linear-gradient(120deg,#ffffff_0%,#ffffff_54%,#f3fbf8_100%)] pt-16 xl:min-h-[76svh]">
        <div class="mx-auto grid w-full max-w-[1440px] items-center gap-8 px-5 py-8 max-[359px]:gap-6 max-[359px]:py-6 sm:px-8 sm:py-10 lg:py-12 xl:grid-cols-[0.82fr_1.18fr] xl:gap-10 xl:px-12 xl:pb-5 xl:pt-14">
          <div class="relative z-10 w-full max-w-[690px]">
            <h1 class="max-w-[650px] font-headline text-4xl font-black leading-[1.03] text-[#0b1422] max-[359px]:text-[2.1rem] sm:text-5xl lg:text-6xl xl:text-7xl">
              Manage rentals before they become work
            </h1>
            <p class="mt-6 max-w-xl text-lg leading-8 text-[#2d3d49] max-[359px]:mt-5 max-[359px]:text-base max-[359px]:leading-7 sm:text-xl">
              Service charges, documents, tenant portal, smoke alarms, messages and deadlines come together in one system.
            </p>
            <div class="mt-8 flex flex-col gap-3 max-[359px]:mt-7 sm:flex-row">
              <a class="inline-flex h-12 items-center justify-center rounded-md bg-[#006b5b] px-6 font-label text-base font-bold text-white shadow-[0_18px_34px_rgba(0,107,91,0.26)] transition hover:-translate-y-0.5 hover:bg-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4 focus-visible:ring-offset-4" href="/warteliste">
                Join the waitlist
                <ArrowRight class="ml-2 h-4 w-4" />
              </a>
              <a class="inline-flex h-12 items-center justify-center rounded-md border border-[rgba(0,107,91,0.45)] bg-white/[0.92] px-6 font-label text-base font-bold text-[#006b5b] shadow-[0_14px_30px_rgba(14,36,43,0.08)] backdrop-blur transition hover:-translate-y-0.5 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href="#features">
                View features
              </a>
            </div>
          </div>

          <div class="relative z-10 min-w-0">
            <div class="relative mx-auto hidden h-[560px] w-full max-w-[780px] overflow-hidden rounded-lg border border-[#dbe3e6] bg-[#faf8ff] text-left shadow-[0_34px_90px_rgba(14,36,43,0.16)] xl:block">
              <div class="flex h-12 items-center justify-between border-b border-slate-200/60 bg-white/[0.88] px-4 backdrop-blur">
                <div class="flex items-center gap-5">
                  <div class="flex items-center gap-2.5">
                    <AppIcon className="h-8 w-8 shadow-sm" />
                    <span class="font-headline text-lg font-black tracking-tight text-brand-wordmark">Mietfolio</span>
                  </div>
                  <div class="hidden items-center gap-4 font-headline text-xs font-bold text-slate-500 lg:flex">
                    {["Overview", "Properties", "Tenants", "Documents", "Messages"].map((item, index) => (
                      <span class={index === 0 ? "text-[#1b6e60]" : ""}>
                        {item}
                      </span>
                    ))}
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <span class="hidden rounded-xl border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 sm:inline-flex">
                    Sample Street 12
                  </span>
                  <MaterialSymbol icon="settings" className="text-lg text-slate-500" />
                  <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[#d0e7e1] text-xs font-black text-[#174f45]">S</span>
                </div>
              </div>

              <div class="grid h-[calc(100%-3rem)] grid-cols-[70px_1fr] md:grid-cols-[184px_1fr]">
                <aside class="border-r border-slate-200/70 bg-[#f2f3ff] px-2 py-3 md:px-3">
                  <div class="mb-4 hidden items-center gap-3 px-2 md:flex">
                    <span aria-hidden="true" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#1b6e60] text-white shadow-sm">
                      <MaterialSymbol icon="home_work" fill className="text-[1.55rem]" />
                    </span>
                    <div class="min-w-0">
                      <p class="truncate font-headline text-xs font-bold text-[#1b6e60]">Sample Street 12</p>
                      <p class="truncate text-[10px] uppercase tracking-widest text-slate-600">Active property</p>
                    </div>
                  </div>
                  <div class="space-y-1">
                    {previewSidebarLinks.map(([icon, label, active]) => (
                      <div
                        class:list={["flex items-center justify-center rounded-lg py-2 text-sm transition md:justify-start md:px-3",
                          active ? "bg-white text-[#1b6e60] shadow-sm" : "text-slate-600"
                        ]}
                      >
                        <MaterialSymbol icon={icon} fill={active} className="text-xl md:mr-3" />
                        <span class="hidden text-xs font-medium md:inline">{label}</span>
                      </div>
                    ))}
                  </div>
                  <div class="mt-4 hidden rounded-xl bg-[#1b6e60] px-3 py-2.5 text-center font-headline text-xs font-bold text-white md:block">
                    New item
                  </div>
                </aside>

                <div class="overflow-hidden bg-[#faf8ff] p-4 md:p-5">
                  <div class="mb-5 flex items-start justify-between gap-4">
                    <div>
                      <p class="font-label text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Overview</p>
                      <h2 class="mt-1 font-headline text-lg font-black leading-tight text-[#131b2e] md:text-2xl">
                        Service charge statement
                      </h2>
                    </div>
                    <div class="hidden items-center gap-2 md:flex">
                      <span class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-bold text-slate-700">{billingYear}</span>
                      <span class="rounded-xl bg-[#1b6e60] px-3 py-2 text-xs font-bold text-white">PDF export</span>
                    </div>
                  </div>

                  <div class="grid grid-cols-3 gap-3">
                    {[
                      ["Total costs", "3,236.90 EUR", "receipt_long"],
                      ["Advance", "2,980.00 EUR", "payments"],
                      ["Balance", "256.90 EUR", "monitoring"],
                    ].map(([label, value, icon]) => (
                      <div class="rounded-2xl bg-white p-4 shadow-sm">
                        <div class="flex items-center justify-between">
                          <span class="text-xs font-semibold text-slate-500">{label}</span>
                          <MaterialSymbol icon={icon} className="text-lg text-[#1b6e60]" />
                        </div>
                        <p class="mt-3 font-headline text-xl font-black text-[#131b2e]">{value}</p>
                      </div>
                    ))}
                  </div>

                  <div class="mt-4 grid gap-4 lg:grid-cols-[1fr_220px]">
                    <div class="rounded-2xl bg-white p-4 shadow-sm">
                      <div class="mb-3 flex items-center justify-between">
                        <h3 class="font-headline text-sm font-black text-[#131b2e]">Cost items</h3>
                        <span class="text-xs font-bold text-[#1b6e60]">AI import</span>
                      </div>
                      <div class="space-y-2">
                        {previewCostItems.map(([title, amount, note, icon]) => (
                          <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 rounded-xl border border-slate-100 px-3 py-2">
                            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-50 text-[#1b6e60]">
                              <MaterialSymbol icon={icon} className="text-lg" />
                            </span>
                            <div class="min-w-0">
                              <p class="truncate text-sm font-bold text-[#131b2e]">{title}</p>
                              <p class="truncate text-xs text-slate-500">{note}</p>
                            </div>
                            <span class="font-label text-sm font-black text-[#131b2e]">{amount}</span>
                          </div>
                        ))}
                      </div>
                    </div>

                    <div class="space-y-4">
                      <div class="rounded-2xl bg-white p-4 shadow-sm">
                        <h3 class="font-headline text-sm font-black text-[#131b2e]">Tasks</h3>
                        <div class="mt-3 space-y-3">
                          {previewReminders.map(([title, date]) => (
                            <div class="flex gap-3">
                              <span class="mt-0.5 h-2.5 w-2.5 rounded-full bg-[#1b6e60]" />
                              <div>
                                <p class="text-xs font-bold text-[#131b2e]">{title}</p>
                                <p class="text-[11px] text-slate-500">{date}</p>
                              </div>
                            </div>
                          ))}
                        </div>
                        <div class="mt-4 flex items-center justify-between rounded-xl bg-[#f8fafb] px-3 py-2">
                          <span class="text-xs font-bold text-slate-500">Tenants</span>
                          <span class="font-headline text-sm font-black text-[#1b6e60]">4 active</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="relative mx-auto h-[232px] w-full max-w-[560px] overflow-hidden rounded-[18px] border border-[#dbe3e6] bg-[#faf8ff] text-left shadow-[0_24px_64px_rgba(14,36,43,0.14)] min-[360px]:h-[250px] md:h-[360px] xl:hidden">
              <div class="flex h-12 items-center justify-between border-b border-slate-200/70 bg-white/92 px-4">
                <div>
                  <p class="font-headline text-base font-black tracking-tight text-[#1b6e60]">Overview</p>
                  <p class="text-[9px] font-bold uppercase tracking-[0.18em] text-slate-500">Sample Street 12</p>
                </div>
                <div class="flex items-center gap-2.5">
                  <span class="rounded-full bg-[#edf8f4] px-2.5 py-1 font-label text-[11px] font-black text-[#1b6e60]">{billingYear}</span>
                  <MaterialSymbol icon="more_vert" className="text-xl text-slate-500" />
                </div>
              </div>

              <div class="px-4 pb-16 pt-3">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-label text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Charges</p>
                    <h2 class="mt-1 truncate font-headline text-lg font-black leading-tight text-[#131b2e]">
                      Review statement
                    </h2>
                  </div>
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#1b6e60] text-white shadow-sm">
                    <MaterialSymbol icon="receipt_long" fill className="text-xl" />
                  </span>
                </div>

                <div class="mt-3 grid grid-cols-2 gap-2.5">
                  <div class="rounded-2xl bg-white p-3 shadow-sm">
                    <div class="flex items-center justify-between gap-2">
                      <span class="text-[11px] font-semibold text-slate-500">Total</span>
                      <MaterialSymbol icon="account_balance_wallet" className="text-base text-[#1b6e60]" />
                    </div>
                    <p class="mt-2 whitespace-nowrap font-headline text-base font-black text-[#131b2e]">3,236.90 EUR</p>
                  </div>
                  <div class="rounded-2xl bg-white p-3 shadow-sm">
                    <div class="flex items-center justify-between gap-2">
                      <span class="text-[11px] font-semibold text-slate-500">Tasks</span>
                      <MaterialSymbol icon="notifications" className="text-base text-[#1b6e60]" />
                    </div>
                    <p class="mt-2 whitespace-nowrap font-headline text-base font-black text-[#131b2e]">3 open</p>
                  </div>
                </div>

                <div class="mt-3 hidden rounded-2xl bg-white p-3 shadow-sm md:block">
                  <div class="mb-2 flex items-center justify-between">
                    <h3 class="font-headline text-sm font-black text-[#131b2e]">Important today</h3>
                    <MaterialSymbol icon="arrow_forward" className="text-base text-[#1b6e60]" />
                  </div>
                  <div class="space-y-2">
                    {mobilePreviewTasks.map(([title, date, icon]) => (
                      <div class="grid grid-cols-[auto_1fr_auto] items-center gap-2 rounded-xl bg-[#f8fafb] px-2.5 py-2">
                        <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-50 text-[#1b6e60]">
                          <MaterialSymbol icon={icon} className="text-base" />
                        </span>
                        <span class="truncate text-xs font-bold text-[#131b2e]">{title}</span>
                        <span class="font-label text-[11px] font-bold text-slate-500">{date}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div class="absolute inset-x-0 bottom-0 grid grid-cols-5 border-t border-slate-200/70 bg-white/95 px-2 pb-2 pt-2 backdrop-blur">
                {mobilePreviewTabs.map(([icon, label, active]) => (
                  <span class:list={["flex min-w-0 flex-col items-center gap-0.5 rounded-xl py-1", active ? "text-[#1b6e60]" : "text-slate-500"]}>
                    <MaterialSymbol icon={icon} fill={active} className="text-xl" />
                    <span class="max-w-full truncate font-label text-[9px] font-bold">{label}</span>
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="border-y border-[#dfe9e6] bg-white" aria-label="Product benefits">
        <div class="mx-auto grid max-w-[1440px] px-5 sm:px-8 md:grid-cols-2 lg:grid-cols-4 lg:px-12">
          {proofItems.map(({ icon: Icon, title, text }, index) => (
            <div
              class:list={[`flex min-h-28 gap-4 border-b border-[#dfe9e6] px-5 py-7 sm:px-6 lg:px-8`,
                index % 2 === 0 ? "md:border-r" : "",
                index >= 2 ? "md:border-b-0" : "",
                "lg:border-b-0 lg:border-r",
                index === proofItems.length - 1 ? "lg:border-r-0" : ""
              ]}
            >
              <span class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-[#d9ebe6] bg-[#f4fbf8] text-[#006b5b]">
                <Icon class="h-5 w-5" strokeWidth={2} />
              </span>
              <div>
                <h2 class="font-headline text-base font-extrabold text-[#0b1422]">{title}</h2>
                <p class="mt-1.5 text-sm leading-6 text-[#5c6b74]">{text}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section id="workflow" class="scroll-mt-20 border-b border-[#dfe9e6] bg-white">
        <div class="mx-auto grid max-w-[1440px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[1.2fr_1fr_1fr_1fr_auto] lg:items-start lg:px-12">
          <div class="lg:pr-4">
            <h2 class="font-headline text-3xl font-black leading-tight text-[#0b1422]">
              Everything under control in three steps
            </h2>
            <p class="mt-4 text-base leading-7 text-[#5c6b74]">
              A clear workflow for less back-and-forth and more time for the important work.
            </p>
            <a
              class="mt-5 inline-flex items-center rounded-md font-label text-sm font-bold text-[#006b5b] transition hover:text-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4"
              href="#features"
            >
              See how it works
              <ArrowRight class="ml-2 h-4 w-4" />
            </a>
          </div>

          <div class="grid gap-8 md:grid-cols-3 md:gap-6 lg:col-span-3 lg:gap-6">
            {workflowSteps.map((step, index) => (
              <article class="relative flex h-full flex-col">
                <div class="relative">
                  {index < workflowSteps.length - 1 ? (
                    <span
                      class="pointer-events-none absolute left-6 top-6 hidden h-px w-[calc(100%+1.5rem)] bg-[rgba(0,107,91,0.45)] lg:block"
                      aria-hidden="true"
                    />
                  ) : null}
                  <div class="relative flex h-12 w-12 items-center justify-center rounded-full border border-[#006b5b] bg-white font-label text-sm font-black text-[#006b5b]">
                    {step.number}
                  </div>
                </div>
                <h3 class="mt-6 font-headline text-lg font-extrabold text-[#0b1422]">{step.title}</h3>
                <p class="mt-3 flex-1 text-sm leading-6 text-[#5c6b74]">{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="features" class="scroll-mt-20 border-b border-[#dfe9e6] bg-[#fbfdfc]">
        <div class="mx-auto max-w-[1440px] px-5 py-16 sm:px-8 lg:px-12">
          <div class="grid gap-8 lg:grid-cols-[260px_1fr]">
            <div>
              <h2 class="font-headline text-3xl font-black leading-tight text-[#0b1422]">
                All core areas. One system.
              </h2>
              <p class="mt-4 text-base leading-7 text-[#5c6b74]">
                Mietfolio connects the central landlord workflows in one shared property context.
              </p>
              <a class="mt-5 inline-flex items-center rounded-md font-label text-sm font-bold text-[#006b5b] transition hover:text-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href="#app-overview">
                View app overview
                <ArrowRight class="ml-2 h-4 w-4" />
              </a>
            </div>

            <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
              {modules.map(({ icon: Icon, title, text, points }) => (
                <article class="group flex min-h-72 flex-col rounded-lg border border-[#dfe9e6] bg-white p-5 shadow-[0_10px_28px_rgba(14,36,43,0.05)] transition duration-200 hover:-translate-y-1 hover:border-[#b9d3cc] hover:shadow-[0_18px_42px_rgba(14,36,43,0.09)]">
                  <Icon class="h-8 w-8 text-[#006b5b]" strokeWidth={1.8} />
                  <h3 class="mt-7 font-headline text-lg font-extrabold text-[#0b1422]">{title}</h3>
                  <p class="mt-3 text-sm leading-6 text-[#5c6b74]">{text}</p>
                  <ul class="mt-4 grid gap-2">
                    {points.map((point) => (
                      <li class="flex gap-2 text-xs font-semibold leading-5 text-[#2d3d49]">
                        <Check class="mt-0.5 h-4 w-4 shrink-0 text-[#006b5b]" strokeWidth={2.2} />
                        <span>{point}</span>
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="app-overview" class="scroll-mt-20 bg-[#003f3f] text-white">
        <div class="mx-auto grid max-w-[1440px] gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[250px_1fr_230px] lg:px-12">
          <div>
            <h2 class="font-headline text-3xl font-black leading-tight">
              Tasks and deadlines at a glance
            </h2>
            <p class="mt-4 text-base leading-7 text-[#c9dfdc]">
              See what needs attention across your properties: statements, messages, maintenance and lease deadlines.
            </p>
            <a class="mt-5 inline-flex items-center rounded-md font-label text-sm font-bold text-[#9de4cf] transition hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9de4cf]/70 focus-visible:ring-offset-4 focus-visible:ring-offset-[#003f3f]" href="/auth">
              Open app
              <ArrowRight class="ml-2 h-4 w-4" />
            </a>
          </div>

          <div class="overflow-hidden rounded-lg border border-white/[0.16] bg-white/[0.05] shadow-[0_26px_60px_rgba(0,0,0,0.22)]">
            <div class="hidden grid-cols-[105px_1.2fr_1fr_120px] gap-4 border-b border-white/10 px-5 py-3 font-label text-xs font-bold uppercase text-[#9de4cf] md:grid">
              <span>Date</span>
              <span>Task</span>
              <span>Property</span>
              <span>Status</span>
            </div>
            <div>
              {operationRows.map(([date, title, property, status, color]) => (
                <div class="grid gap-2 border-b border-white/10 px-4 py-4 text-sm last:border-b-0 md:grid-cols-[105px_1.2fr_1fr_120px] md:items-center md:gap-4 md:px-5">
                  <span class="font-label text-xs font-bold uppercase tracking-[0.16em] text-[#9de4cf] md:text-sm md:font-normal md:normal-case md:tracking-normal md:text-[#d9efea]">{date}</span>
                  <span class="flex min-w-0 items-center gap-3 font-semibold">
                    <span class={`h-2.5 w-2.5 shrink-0 rounded-full ${color}`} />
                    <span class="truncate">{title}</span>
                  </span>
                  <span class="truncate text-[#c9dfdc]">{property}</span>
                  <span class="w-fit rounded-md border border-[rgba(157,228,207,0.3)] bg-[rgba(157,228,207,0.12)] px-2.5 py-1 font-label text-xs font-bold text-[#9de4cf]">{status}</span>
                </div>
              ))}
            </div>
          </div>

          <aside class="rounded-lg border border-white/[0.16] bg-white/[0.06] p-5">
            <div class="flex items-center justify-between">
              <h3 class="font-headline text-lg font-extrabold">Open messages</h3>
              <span class="rounded-md bg-[rgba(157,228,207,0.15)] px-2 py-1 font-label text-xs font-bold text-[#9de4cf]">3</span>
            </div>
            <div class="mt-5 space-y-4">
              {messageItems.map((item, index) => (
                <div class="flex gap-3">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#f3c47c] font-label text-xs font-black text-[#3d2604]">
                    {index + 1}
                  </span>
                  <div>
                    <p class="font-label text-sm font-bold">{item}</p>
                    <p class="mt-0.5 text-xs text-[#c9dfdc]">{index === 0 ? "Today" : index === 1 ? "Yesterday" : "2 days ago"}</p>
                  </div>
                </div>
              ))}
            </div>
            <a class="mt-6 inline-flex items-center rounded-md font-label text-sm font-bold text-[#9de4cf] transition hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#9de4cf]/70 focus-visible:ring-offset-4 focus-visible:ring-offset-[#003f3f]" href="/auth">
              View all messages
              <ArrowRight class="ml-2 h-4 w-4" />
            </a>
          </aside>
        </div>
      </section>

      <section id="security" class="scroll-mt-20 border-b border-[#dfe9e6] bg-white">
        <div class="mx-auto grid max-w-[1440px] items-center gap-8 px-5 py-12 sm:px-8 lg:grid-cols-[260px_1fr] lg:px-12">
          <div class="flex items-center gap-5">
            <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-[#dfe9e6] bg-white text-[#006b5b] shadow-[0_16px_36px_rgba(14,36,43,0.08)]">
              <LockKeyhole class="h-7 w-7" strokeWidth={1.8} />
            </span>
            <h2 class="font-headline text-3xl font-black leading-tight text-[#0b1422]">
              Your data. Your control.
            </h2>
          </div>
          <div class="grid gap-5 md:grid-cols-4">
            {securityItems.map((item) => (
              <div class="flex gap-3 border-t border-[#dfe9e6] pt-5 md:border-l md:border-t-0 md:pl-5 md:pt-0">
                <Check class="mt-0.5 h-5 w-5 shrink-0 text-[#006b5b]" strokeWidth={2.2} />
                <p class="text-sm font-semibold leading-6 text-[#2d3d49]">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="pricing" class="scroll-mt-20 border-b border-[#dfe9e6] bg-[#fbfdfc]">
        <div class="mx-auto grid max-w-[1440px] gap-8 px-5 py-16 sm:px-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:px-12">
          <div>
            <h2 class="font-headline text-3xl font-black leading-tight text-[#0b1422] md:text-4xl">
              Launching soon. Waitlist open.
            </h2>
            <p class="mt-4 max-w-xl text-base leading-7 text-[#5c6b74]">
              Registration is currently paused. Join the waitlist and we will let you know when new app access opens.
            </p>
            <a class="mt-6 inline-flex h-12 items-center justify-center rounded-md bg-[#006b5b] px-6 font-label text-base font-bold text-white shadow-[0_18px_34px_rgba(0,107,91,0.22)] transition hover:-translate-y-0.5 hover:bg-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4" href="/warteliste">
              Join the waitlist
              <ArrowRight class="ml-2 h-4 w-4" />
            </a>
          </div>

          <div class="grid gap-4 md:grid-cols-[1fr_0.82fr]">
            <article class="rounded-lg border border-[#dfe9e6] bg-white p-6 shadow-[0_18px_42px_rgba(14,36,43,0.07)]">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <h3 class="font-headline text-xl font-black text-[#0b1422]">Start</h3>
                  <p class="mt-1 text-sm leading-6 text-[#5c6b74]">For the first real daily review.</p>
                </div>
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[#e7f7f1] text-[#006b5b]">
                  <Euro class="h-5 w-5" strokeWidth={2.2} />
                </span>
              </div>
              <p class="mt-7 font-headline text-4xl font-black text-[#0b1422]">Free</p>
              <p class="mt-2 text-sm font-semibold text-[#5c6b74]">Start without automatic payment.</p>
              <ul class="mt-6 space-y-3">
                {pricingPoints.map((item) => (
                  <li class="flex gap-3 text-sm leading-6 text-[#2d3d49]">
                    <Check class="mt-0.5 h-5 w-5 shrink-0 text-[#006b5b]" strokeWidth={2.2} />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>

            <div class="grid gap-4">
              <article class="rounded-lg border border-[#dfe9e6] bg-white p-5">
                <Server class="h-7 w-7 text-[#006b5b]" strokeWidth={1.8} />
                <h3 class="mt-5 font-headline text-lg font-extrabold text-[#0b1422]">Data separated deliberately</h3>
                <p class="mt-3 text-sm leading-6 text-[#5c6b74]">
                  Property and user data remain in the intended app context.
                </p>
              </article>
              <article class="rounded-lg border border-[#dfe9e6] bg-white p-5">
                <FileText class="h-7 w-7 text-[#006b5b]" strokeWidth={1.8} />
                <h3 class="mt-5 font-headline text-lg font-extrabold text-[#0b1422]">No advisory promise</h3>
                <p class="mt-3 text-sm leading-6 text-[#5c6b74]">
                  Mietfolio helps with organization and exports, but does not replace individual legal or tax advice.
                </p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section id="faq" class="scroll-mt-20 border-b border-[#dfe9e6] bg-white">
        <div class="mx-auto grid max-w-[1440px] gap-8 px-5 py-16 sm:px-8 lg:grid-cols-[300px_1fr] lg:px-12">
          <div>
            <h2 class="font-headline text-3xl font-black leading-tight text-[#0b1422]">
              Frequently asked questions
            </h2>
            <p class="mt-4 text-base leading-7 text-[#5c6b74]">
              The most important answers before the first login.
            </p>
            <a class="mt-5 inline-flex items-center rounded-md font-label text-sm font-bold text-[#006b5b] transition hover:text-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4" href="/kontakt">
              Ask a question
              <Mail class="ml-2 h-4 w-4" />
            </a>
          </div>

          <div class="grid gap-3 md:grid-cols-2">
            {faqItems.map((item) => (
              <details class="group rounded-lg border border-[#dfe9e6] bg-[#fbfdfc] p-5 open:bg-white open:shadow-[0_16px_36px_rgba(14,36,43,0.06)]">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-headline text-base font-extrabold text-[#0b1422] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35">
                  <span>{item.question}</span>
                  <ChevronRight class="mt-0.5 h-4 w-4 shrink-0 text-[#006b5b] transition group-open:rotate-90" strokeWidth={2.2} />
                </summary>
                <p class="mt-4 text-sm leading-6 text-[#5c6b74]">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="bg-[#003f3f] text-white">
        <div class="mx-auto flex max-w-[1440px] flex-col gap-8 px-5 py-16 sm:px-8 md:flex-row md:items-center md:justify-between lg:px-12">
          <div>
            <h2 class="font-headline text-3xl font-black leading-tight md:text-4xl">
              Reserve access and start later.
            </h2>
            <p class="mt-3 max-w-2xl text-base leading-7 text-[#c9dfdc]">
              Registration opens in stages. The waitlist is currently the way to request new access.
            </p>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a class="inline-flex h-12 items-center justify-center rounded-md bg-white px-6 font-label text-base font-bold text-[#003f3f] transition hover:-translate-y-0.5 hover:bg-[#e9f6f2] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 focus-visible:ring-offset-4 focus-visible:ring-offset-[#003f3f]" href="/warteliste">
              Join the waitlist
              <ArrowRight class="ml-2 h-4 w-4" />
            </a>
            <a class="inline-flex h-12 items-center justify-center rounded-md border border-white/[0.28] px-6 font-label text-base font-bold text-white transition hover:-translate-y-0.5 hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/70 focus-visible:ring-offset-4 focus-visible:ring-offset-[#003f3f]" href="#features">
              View features
            </a>
          </div>
        </div>
      </section>
    </main>
  </div>

  <Footer locale="en" />
</Layout>
