---
import BrandLogo from "./BrandLogo.astro";
import { Menu, X } from "@lucide/astro";

const navItems = [
  ["Funktionen", "/#funktionen"],
  ["Ablauf", "/#ablauf"],
  ["Sicherheit", "/#sicherheit"],
  ["Preis", "/#preis"],
  ["FAQ", "/#faq"],
] as const;
---
<header class="fixed inset-x-0 top-0 z-50 border-b border-[rgba(215,227,224,0.7)] bg-white/[0.94] backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-[1440px] items-center justify-between gap-2 px-4 sm:gap-3 sm:px-8 lg:px-12">
    <a
      class="rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4"
      href="/"
      aria-label="Mietfolio Startseite"
    >
      <BrandLogo
        iconClassName="h-9 w-9 border border-[rgba(10,102,87,0.15)] shadow-[0_8px_24px_rgba(3,36,32,0.08)] sm:h-10 sm:w-10"
        textClassName="font-headline text-xl font-black text-brand-wordmark sm:text-2xl"
      />
    </a>
    <nav class="hidden items-center gap-5 font-label text-xs font-semibold text-[#2d3d49] md:flex lg:gap-9 lg:text-sm" aria-label="Hauptnavigation">
      {navItems.map(([label, href]) => (
        <a
          class="rounded-md transition hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4"
          href={href}
        >
          {label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2 sm:gap-3">
      <a class="hidden rounded-md px-3 py-2 font-label text-sm font-semibold text-[#2d3d49] transition hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35 focus-visible:ring-offset-4 sm:inline-flex" href="/auth">
        Login
      </a>
      <a class="inline-flex h-10 items-center justify-center rounded-md bg-[#006b5b] px-3 font-label text-sm font-bold text-white shadow-[0_10px_24px_rgba(0,107,91,0.24)] transition hover:bg-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4 max-[359px]:hidden sm:px-4" href="/warteliste">
        Warteliste
      </a>
      <button
        id="mobile-menu-button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-[#d7e3e0] bg-white text-[#006b5b] shadow-[0_8px_22px_rgba(14,36,43,0.08)] transition hover:border-[#006b5b]/45 hover:bg-[#f7fbf9] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45 focus-visible:ring-offset-4 md:hidden"
        type="button"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <span id="menu-open-icon" class="inline-flex"><Menu class="h-5 w-5" stroke-width={2.2} /></span>
        <span id="menu-close-icon" class="hidden"><X class="h-5 w-5" stroke-width={2.2} /></span>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden h-[calc(100dvh-4rem)] overflow-y-auto border-t border-[#d7e3e0]/80 bg-white/[0.96] px-4 py-4 shadow-[0_18px_44px_rgba(14,36,43,0.12)] backdrop-blur-xl md:hidden">
    <nav class="mx-auto grid max-w-[1440px] gap-1 font-label text-sm font-bold text-[#2d3d49]" aria-label="Mobile Hauptnavigation">
      {navItems.map(([label, href]) => (
        <a
          class="rounded-md px-3 py-3 transition hover:bg-[#f4faf7] hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35"
          href={href}
        >
          {label}
        </a>
      ))}
      <a
        class="rounded-md px-3 py-3 transition hover:bg-[#f4faf7] hover:text-[#006b5b] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/35"
        href="/auth"
      >
        Login
      </a>
      <a
        class="mt-2 inline-flex h-11 items-center justify-center rounded-md bg-[#006b5b] px-4 font-bold text-white shadow-[0_12px_28px_rgba(0,107,91,0.22)] transition hover:bg-[#005346] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#006b5b]/45"
        href="/warteliste"
      >
        Warteliste
      </a>
    </nav>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  button?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    if (isHidden) {
      menu?.classList.remove('hidden');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      button.setAttribute('aria-expanded', 'true');
      button.setAttribute('aria-label', 'Menü schließen');
    } else {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      button.setAttribute('aria-expanded', 'false');
      button.setAttribute('aria-label', 'Menü öffnen');
    }
  });

  // Close mobile menu on link clicks
  const links = menu?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      button?.setAttribute('aria-expanded', 'false');
      button?.setAttribute('aria-label', 'Menü öffnen');
    });
  });
</script>
