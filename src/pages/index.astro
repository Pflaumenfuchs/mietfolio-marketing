  FileText,
  FolderOpen,
  Home,
  LockKeyhole,
  Mail,
  ReceiptText,
  Server,
  ShieldCheck,
  UsersRound,
  Radio,
} from "@lucide/astro";

const navItems = [
  ["Funktionen", "#funktionen"],
