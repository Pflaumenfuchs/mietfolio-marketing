---
interface Props {
  alt?: string;
  className?: string;
  imageClassName?: string;
}

const { alt = "", className = "", imageClassName = "" } = Astro.props;
---
<span class:list={["inline-flex shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white", className]}>
  <!-- ⚡ Bolt: Inlined SVG to prevent render-blocking HTTP request and improve LCP/FCP -->
  <svg
    aria-label={alt}
    role="img"
    class:list={["h-full w-full object-contain", imageClassName]}
    viewBox="0 0 100 100"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <rect width="100" height="100" rx="20" fill="#faf8ff"/>
    <rect x="10" y="10" width="24" height="24" rx="2" fill="#003441"/>
    <rect x="66" y="10" width="24" height="24" rx="2" fill="#003441"/>
    <rect x="10" y="38" width="24" height="24" rx="2" fill="#003441"/>
    <rect x="38" y="38" width="24" height="24" rx="2" fill="#003441"/>
    <rect x="66" y="38" width="24" height="24" rx="2" fill="#003441"/>
    <rect x="10" y="66" width="24" height="24" rx="2" fill="#003441"/>
    <rect x="66" y="66" width="24" height="24" rx="2" fill="#003441"/>
  </svg>
</span>
